generator client {
  provider = "prisma-client-js"
  // Add the output path below
  output   = "../node_modules/.prisma/client" // Standard output path relative to schema.prisma
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id                Int    @id @default(autoincrement())
  scaleId           Int
  operatorId        Int
  initialMass       Float
  tareMass          Float
  fillMass          Float
  lastMeasurement   Float
  fillSequence      Int
  statusCode        Int
  createdAt         DateTime @default(now())
}
